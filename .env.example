# Server
PORT=3000
NODE_ENV=development

# Database (cPanel MySQL account/db/user names are typically prefixed, e.g. cpaneluser_hyt)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hyt_tours
DB_USER=hyt_user
DB_PASSWORD=changeme

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Seed admin user (used only by seeders/*-demo-admin-user.js)
SEED_ADMIN_EMAIL=admin@hytours.com
SEED_ADMIN_PASSWORD=changeme123
