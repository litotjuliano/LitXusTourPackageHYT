<%- include('../partials/header', { title: 'Tours', currentAdmin }) %>

<h1>Tours</h1>
<p><a href="/admin/tours/new" class="btn btn-primary">+ New Tour</a></p>

<table>
  <thead>
    <tr><th></th><th>Title</th><th>Price</th><th>Departure Dates</th><th>PDF</th><th></th></tr>
  </thead>
  <tbody id="tours-tbody">
  <% tours.forEach(function(tour) { %>
    <tr draggable="true" data-id="<%= tour.id %>">
      <td>
        <div class="reorder-cell">
          <button type="button" class="btn btn-icon drag-handle" title="Drag to reorder" aria-label="Drag to reorder">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="9" cy="6" r="1.8"/><circle cx="9" cy="12" r="1.8"/><circle cx="9" cy="18" r="1.8"/><circle cx="15" cy="6" r="1.8"/><circle cx="15" cy="12" r="1.8"/><circle cx="15" cy="18" r="1.8"/></svg>
          </button>
          <div class="reorder-arrows">
            <button type="button" class="btn btn-icon btn-icon-sm move-up-btn" title="Move up" aria-label="Move up">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
            </button>
            <button type="button" class="btn btn-icon btn-icon-sm move-down-btn" title="Move down" aria-label="Move down">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
          </div>
        </div>
      </td>
      <td><%= tour.title %></td>
      <td>RM <%= tour.price %></td>
      <td><%= tour.departure_dates || '—' %></td>
      <td>
        <% if (tour.pdf_url) { %>
          <a href="<%= tour.pdf_url %>" target="_blank" class="btn btn-icon" title="View PDF" aria-label="View PDF">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </a>
        <% } else { %>—<% } %>
      </td>
      <td>
        <a href="/admin/tours/<%= tour.id %>/edit" class="btn btn-icon" title="Edit" aria-label="Edit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
        </a>
        <form method="POST" action="/admin/tours/<%= tour.id %>/delete" onsubmit="return confirm('Delete this tour?');" style="display:inline;">
          <button type="submit" class="btn btn-danger btn-icon" title="Delete" aria-label="Delete">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          </button>
        </form>
      </td>
    </tr>
  <% }); %>
  </tbody>
</table>

<script src="/js/admin-tours-reorder.js"></script>

<%- include('../partials/footer') %>
