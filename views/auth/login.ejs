<%- include('../partials/header', { title: 'Login' }) %>

<div class="login-wrap">
  <div class="card">
    <h1>HYT Admin Login</h1>
    <form method="POST" action="/admin/login">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required>
      </div>
      <button type="submit" class="btn btn-primary">Log in</button>
    </form>

    <% if (typeof devCredentials !== 'undefined' && devCredentials) { %>
      <div class="dev-cheatsheet">
        <p class="dev-cheatsheet-title">Dev login (not shown in production) &mdash; click to autofill</p>
        <p>Email: <code id="dev-cred-email" class="dev-cred-value" data-value="<%= devCredentials.email %>"><%= devCredentials.email %></code></p>
        <p>Password: <code id="dev-cred-password" class="dev-cred-value" data-value="<%= devCredentials.password %>"><%= devCredentials.password %></code></p>
      </div>
      <script>
        document.getElementById('dev-cred-email').addEventListener('click', function () {
          document.getElementById('email').value = this.dataset.value;
          document.getElementById('password').value = document.getElementById('dev-cred-password').dataset.value;
        });
        document.getElementById('dev-cred-password').addEventListener('click', function () {
          document.getElementById('password').value = this.dataset.value;
        });
      </script>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
